# MinimumViablePet configuration. Every variable is optional — the defaults
# below are what you get with no .env at all. Copy to .env and edit, or set
# in your environment.

# HTTP port for the landing pages, the app, and the API.
PORT=8091

# Landing-page waitlist database (SQLite, WAL).
WAITLIST_DB=./data/waitlist.db

# Where companions live: mvp.db, original files, everything. Deliberately
# OUTSIDE the repo by default — your grief archive is not a git artifact.
MVP_DATA_DIR=~/.mvp

# Your local Ollama.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Chat/persona model. Any Ollama chat model works; an 8B-class model is fine
# on 16GB machines (e.g. qwen3:8b). The default is what this was built on.
MVP_CHAT_MODEL=glm-4.7-flash:q8_0

# Vision model for photos and video frames. Must report the "vision"
# capability (ollama show <model>).
MVP_VISION_MODEL=qwen3-vl:8b

# Embedding model for memory retrieval. Changing it means re-embedding:
# run `mvp train <companion>` afterwards. Dims must match MVP_EMBED_DIMS.
MVP_EMBED_MODEL=mxbai-embed-large
MVP_EMBED_DIMS=1024

# Ollama keep_alive for the chat model. Long chats stay warm; never use -1
# on a machine that runs other models.
MVP_KEEP_ALIVE=10m

# Speech-to-text for voice memos and video audio. The flavor is detected
# from the binary name; MODEL means different things per flavor:
#   mlx_whisper (uv tool install mlx-whisper)  -> HF repo, e.g. mlx-community/whisper-large-v3-turbo
#   whisper-cli (brew install whisper-cpp)     -> a ggml model FILE path
#   whisper     (brew install openai-whisper)  -> a model name: base | medium | large-v3
# Missing binary = audio files fail loudly with the install command.
MVP_WHISPER_BIN=mlx_whisper
MVP_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Text-to-speech for the per-reply "speak" button — an interface voice on
# loan to the shape, never presented as theirs. Flavor detected from the
# binary name; VOICE means different things per flavor:
#   say       (ships with macOS)               -> a voice name, e.g. Samantha
#   espeak-ng (apt/brew install espeak-ng)     -> a voice code, e.g. en-us
#   piper     (pip install piper-tts)          -> an .onnx voice model FILE path (required)
# Missing binary = the button fails loudly with the install command.
# Defaults: `say` on macOS, `espeak-ng` elsewhere.
#MVP_TTS_BIN=say
#MVP_TTS_VOICE=

# Per-request upload cap in megabytes (per-file caps are stricter and typed).
MVP_MAX_UPLOAD_MB=200

# Living-memory tuning: facts kept per companion, and the extractor
# confidence needed to keep one.
MVP_MAX_FACTS=500
MVP_FACT_CONFIDENCE=0.6

# Token budget for retrieved memories injected into each reply.
MVP_MAX_INJECTION_TOKENS=4000

# Set to 1 ONLY on a public deploy: serves the landing pages + waitlist
# alone, binds all interfaces, never imports the engine, never creates a
# companion database. Local default (unset) is the full product, bound to
# 127.0.0.1 only.
MVP_PUBLIC=

# Where the mvp CLI finds the engine (the --server flag overrides).
MVP_SERVER_URL=http://127.0.0.1:8091
